                        },
                        "total": {
                          "type": "integer"
                        },
                        "completed": {
                          "type": "integer"
                        },
                        "creditsUsed": {
                          "type": "integer"
                        },
                        "results": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "url": {
                                "type": "string"
                              },
                              "success": {
                                "type": "boolean"
                              },
                              "extract": {
                                "type": "object"
                              },
                              "error": {
                                "type": "object",
                                "properties": {
                                  "code": {
